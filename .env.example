# Paths (relative to repo root)
HC_DATA_RAW_DIR=data/raw
HC_DATA_PROCESSED_DIR=data/processed
HC_ARTIFACTS_DIR=artifacts

# API
HC_API_HOST=127.0.0.1
HC_API_PORT=8000
HC_EXPERIMENTAL_CONDITION=baseline  # baseline | xai | llm

# LLM (optional — template provider used when blank)
HC_LLM_PROVIDER=
HC_LLM_API_KEY=
HC_LLM_MODEL=

# Study instrumentation (Phase 8)
HC_STUDY_ID=pilot-001
HC_LOG_EVENTS=true  # writes artifacts/logs/events.jsonl + events.sqlite
